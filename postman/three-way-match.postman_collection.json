{
  "info": {
    "_postman_id": "b7b9b8e7-4b3e-4a50-9f2c-1c7df4e4b0e1",
    "name": "Three-Way Match Engine",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/health", "host": [ "{{baseUrl}}" ], "path": [ "health" ] }
      }
    },
    {
      "name": "Upload Document (PO/GRN/Invoice)",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "documentType", "value": "po", "type": "text" },
            { "key": "file", "type": "file", "src": [] }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/documents/upload",
          "host": [ "{{baseUrl}}" ],
          "path": [ "documents", "upload" ]
        }
      }
    },
    {
      "name": "Get Document by ID",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/documents/:id?includeRaw=false",
          "host": [ "{{baseUrl}}" ],
          "path": [ "documents", ":id" ],
          "query": [
            { "key": "includeRaw", "value": "false" }
          ]
        }
      }
    },
    {
      "name": "Get Match by PO Number",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/match/:poNumber?includeDebug=false",
          "host": [ "{{baseUrl}}" ],
          "path": [ "match", ":poNumber" ],
          "query": [
            { "key": "includeDebug", "value": "false" }
          ]
        }
      }
    }
  ]
}

